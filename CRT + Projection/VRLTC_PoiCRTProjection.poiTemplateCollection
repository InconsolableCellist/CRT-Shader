#T#CRTProjVertexMods
//ifex _EnableCRTProj==0
#ifdef POI_CRTPROJ
{
    // =========================================================================
    // Vertex Projection - Flatten mesh onto a plane
    // =========================================================================
    float3 projPos = v.vertex.xyz;
    float3 projNormal = v.normal;

    // Determine which axis to flatten and which axes form the screen plane
    // _CRTProjAxis: 0=X, 1=Y, 2=Z
    float2 screenPos;
    float depthVal;

    if (_CRTProjAxis < 1)
    {
        screenPos = projPos.yz;
        depthVal = projPos.x;
    }
    else if (_CRTProjAxis < 2)
    {
        screenPos = projPos.xz;
        depthVal = projPos.y;
    }
    else
    {
        screenPos = projPos.xy;
        depthVal = projPos.z;
    }

    // Scale and offset the screen-plane coordinates
    screenPos = (screenPos - _CRTProjPivot) * _CRTProjScale + _CRTProjPivot + _CRTProjOffset;

    // Flatten: set the depth axis to the plane position
    depthVal = _CRTProjPlanePos;

    // Apply curvature (dome shape)
    if (_CRTProjCurvatureEnabled > 0)
    {
        float2 cc = screenPos - _CRTProjPivot - _CRTProjOffset;
        depthVal += dot(cc, cc) * _CRTProjCurvature;
    }

    // Apply depth offset to prevent Z-fighting with CRT housing
    depthVal += _CRTProjDepthOffset;

    // Write back to vertex
    if (_CRTProjAxis < 1)
    {
        projPos.yz = screenPos;
        projPos.x = depthVal;
    }
    else if (_CRTProjAxis < 2)
    {
        projPos.xz = screenPos;
        projPos.y = depthVal;
    }
    else
    {
        projPos.xy = screenPos;
        projPos.z = depthVal;
    }

    v.vertex.xyz = projPos;

    // Optionally flatten normals to face the projection direction
    if (_CRTProjFlattenNormals > 0)
    {
        if (_CRTProjAxis < 1) v.normal = float3(-1, 0, 0);
        else if (_CRTProjAxis < 2) v.normal = float3(0, -1, 0);
        else v.normal = float3(0, 0, -1);
    }
}
#endif
//endex

#T#CRTProjFragFunction
//ifex _EnableCRTProj==0
#ifdef POI_CRTPROJ
    // =========================================================================
    // CRT Projection Overlay Effects
    // Applies CRT visual effects to the mesh's own rendered output.
    // Derived from cool-retro-term by Swordfish90 (GPL-3.0)
    // =========================================================================

    // --- Procedural noise ---
    float crtProjHash12(float2 p)
    {
        float3 p3 = frac(float3(p.xyx) * 0.1031);
        p3 += dot(p3, p3.yzx + 33.33);
        return frac((p3.x + p3.y) * p3.z);
    }

    // --- Scanlines ---
    // Derived from cool-retro-term terminal_dynamic.frag:66-117
    float3 crtProjScanlines(float3 texel, float2 screenCoords, float2 virtualRes, float intensity)
    {
        float brightBoost = 0.30;
        float scanIntensity = 0.30;

        float3 pixelHigh = ((1.0 + brightBoost) - (0.2 * texel)) * texel;
        float3 pixelLow = ((1.0 - scanIntensity) + (0.1 * texel)) * texel;

        float2 coords = frac(screenCoords * virtualRes) * 2.0 - float2(1.0, 1.0);
        float mask = 1.0 - abs(coords.y);

        float3 rasterColor = lerp(pixelLow, pixelHigh, mask);
        return lerp(texel, rasterColor, intensity);
    }

    // --- Pixel grid ---
    float3 crtProjPixelGrid(float3 texel, float2 screenCoords, float2 virtualRes, float intensity)
    {
        float brightBoost = 0.30;
        float scanIntensity = 0.30;

        float3 pixelHigh = ((1.0 + brightBoost) - (0.2 * texel)) * texel;
        float3 pixelLow = ((1.0 - scanIntensity) + (0.1 * texel)) * texel;

        float2 coords = frac(screenCoords * virtualRes) * 2.0 - float2(1.0, 1.0);
        coords = coords * coords;
        float mask = 1.0 - coords.x - coords.y;

        float3 rasterColor = lerp(pixelLow, pixelHigh, mask);
        return lerp(texel, rasterColor, intensity);
    }

    // --- Subpixel simulation ---
    float3 crtProjSubpixel(float3 texel, float2 screenCoords, float2 virtualRes, float intensity)
    {
        float brightBoost = 0.30;
        float scanIntensity = 0.30;
        float subpixels = 3.0;

        float3 pixelHigh = ((1.0 + brightBoost) - (0.2 * texel)) * texel;
        float3 pixelLow = ((1.0 - scanIntensity) + (0.1 * texel)) * texel;

        float2 coords = frac(screenCoords * virtualRes) * 2.0 - float2(1.0, 1.0);
        float yMask = 1.0 - abs(coords.y);

        float3 offsets = 3.14159265 * float3(0.5, 0.5 - 0.6667, 0.5 - 1.3333);
        float2 omega = 3.14159265 * 2.0 * virtualRes;
        float2 angle = screenCoords * omega;
        float3 xfactors = (subpixels + sin(angle.x + offsets)) / (subpixels + 1.0);

        float3 rasterColor = lerp(pixelLow, pixelHigh, yMask) * xfactors;
        return lerp(texel, rasterColor, intensity);
    }

    // --- Glow line ---
    // Derived from cool-retro-term terminal_dynamic.frag:119-121
    float crtProjGlowLine(float2 coords, float2 virtualRes, float speed)
    {
        float threshold = (virtualRes.y + 120.0) * frac(_Time.y * speed);
        float coordY = coords.y * virtualRes.y;
        return frac(smoothstep(-120.0, 0.0, coordY - threshold));
    }

    // --- Chroma / color conversion ---
    // Derived from cool-retro-term terminal_dynamic.frag:123-132
    float3 crtProjApplyChroma(float3 texColor, float3 fontColor, float3 bgColor, float chromaAmount)
    {
        float grey = dot(texColor, float3(0.299, 0.587, 0.114));
        float3 monoColor = lerp(bgColor, fontColor, grey);
        return lerp(monoColor, texColor, chromaAmount);
    }

    // --- Main CRT Projection overlay function ---
    void applyCRTProjection(inout PoiFragData poiFragData, in PoiMesh poiMesh, in PoiCam poiCam, in PoiLight poiLight, in PoiMods poiMods)
    {
        // Check global mask
        float projMask = 1.0;
        if (_CRTProjGlobalMask > 0)
        {
            projMask = maskBlend(projMask, poiMods.globalMask[_CRTProjGlobalMask - 1], _CRTProjGlobalMaskBlendType);
        }
        if (projMask <= 0.001) return;

        // Merge emission into finalColor so ALL visual content goes through CRT filter
        poiFragData.finalColor += poiFragData.emission * poiMods.globalEmission;
        poiFragData.emission = float3(0, 0, 0);

        // Get screen UV from configured mesh UV channel
        float2 screenUV = poiMesh.uv[_CRTProjScreenUV];

        // Get the current rendered color
        float3 screenColor = poiFragData.finalColor;

        // =================================================================
        // Apply CRT color conversion (chroma / monochrome)
        // =================================================================
        float3 fontColor = poiThemeColor(poiMods, _CRTProjFontColor.rgb, _CRTProjFontColorThemeIndex);
        screenColor = crtProjApplyChroma(screenColor, fontColor, _CRTProjBackgroundColor.rgb, _CRTProjChromaColor);

        // =================================================================
        // Apply rasterization (scanlines / pixel grid / subpixel)
        // =================================================================
        if (_CRTProjRasterMode > 0)
        {
            if (_CRTProjRasterMode < 2)
            {
                screenColor = crtProjScanlines(screenColor, screenUV, _CRTProjVirtualRes, _CRTProjRasterIntensity);
            }
            else if (_CRTProjRasterMode < 3)
            {
                screenColor = crtProjPixelGrid(screenColor, screenUV, _CRTProjVirtualRes, _CRTProjRasterIntensity);
            }
            else
            {
                screenColor = crtProjSubpixel(screenColor, screenUV, _CRTProjVirtualRes, _CRTProjRasterIntensity);
            }
        }

        // =================================================================
        // Add static noise
        // Derived from cool-retro-term terminal_dynamic.frag:149
        // =================================================================
        if (_CRTProjNoiseEnabled > 0)
        {
            float2 noiseScrollUV = screenUV * (_CRTProjVirtualRes.x * 0.75 / 512.0)
                + float2(frac(_Time.y / 0.051), frac(_Time.y / 0.237));
            float noiseVal = crtProjHash12(noiseScrollUV * 512.0);

            float dist = length(float2(0.5, 0.5) - screenUV);
            noiseVal *= _CRTProjNoiseIntensity * (1.0 - dist * 1.3);
            screenColor += float3(noiseVal, noiseVal, noiseVal);
        }

        // =================================================================
        // Add glow line
        // =================================================================
        if (_CRTProjGlowLineEnabled > 0)
        {
            float glowLine = crtProjGlowLine(screenUV, _CRTProjVirtualRes, _CRTProjGlowLineSpeed);
            screenColor += float3(glowLine, glowLine, glowLine) * _CRTProjGlowLineIntensity * 0.2;
        }

        // =================================================================
        // Apply flickering brightness
        // Derived from cool-retro-term terminal_dynamic.vert:42-45
        // =================================================================
        if (_CRTProjFlickerEnabled > 0)
        {
            float2 frameNoiseUV = float2(frac(_Time.y / 2.048), frac(_Time.y / 1048.576));
            float flickerNoise = crtProjHash12(frameNoiseUV * 512.0 + float2(17.31, 43.71));
            float flickerBrightness = 1.0 + (flickerNoise - 0.5) * _CRTProjFlickerIntensity;
            screenColor *= flickerBrightness;
        }

        // =================================================================
        // Apply brightness
        // =================================================================
        screenColor *= _CRTProjBrightness;

        // =================================================================
        // Hue shift
        // =================================================================
        if (_CRTProjHueShiftEnabled > 0)
        {
            screenColor = hueShift(screenColor, frac(_CRTProjHueShift + _CRTProjHueShiftSpeed * _Time.x), _CRTProjHueShiftColorSpace, 1);
        }

        // =================================================================
        // Audio Link
        // =================================================================
        #ifdef POI_AUDIOLINK
            if (poiMods.audioLinkAvailable && _CRTProjALEnabled > 0)
            {
                // Intensity modulation
                float alIntensity = poiMods.audioLink[_CRTProjALBand];
                screenColor *= lerp(_CRTProjALMultipliers.x, _CRTProjALMultipliers.y, alIntensity);

                // Audio-driven hue shift
                if (_CRTProjALHueShift > 0)
                {
                    float alHueShift = poiMods.audioLink[_CRTProjALHueBand] * _CRTProjALHueShiftAmount;
                    screenColor = hueShift(screenColor, alHueShift, 0, 0);
                }
            }
        #endif

        // =================================================================
        // Final output
        // =================================================================
        poiFragData.finalColor = lerp(poiFragData.finalColor, screenColor, projMask);
    }
#endif
//endex

#T#CRTProjFragCall
//ifex _EnableCRTProj==0
