    // --- Procedural noise (not derived from cool-retro-term) ---
    float crtHash12(float2 p)
    {
        float3 p3 = frac(float3(p.xyx) * 0.1031);
        p3 += dot(p3, p3.yzx + 33.33);
        return frac((p3.x + p3.y) * p3.z);
    }

    float crtHash11(float p)
    {
        p = frac(p * 0.1031);
        p *= p + 33.33;
        p *= p + p;
        return frac(p);
    }

    float2 crtHash22(float2 p)
    {
        float3 p3 = frac(float3(p.xyx) * float3(0.1031, 0.1030, 0.0973));
        p3 += dot(p3, p3.yzx + 33.33);
        return frac((p3.xx + p3.yz) * p3.zy);
    }

    // --- Screen curvature: barrel distortion ---
    // Derived from cool-retro-term terminal_dynamic.frag:59-64
    float2 crtDistortCoordinates(float2 coords, float curvature)
    {
        float2 cc = coords - float2(0.5, 0.5);
        float dist = dot(cc, cc) * curvature;
        return coords + cc * (1.0 + dist) * dist;
    }

    // --- Rasterization modes ---
    // Derived from cool-retro-term terminal_dynamic.frag:66-117

    // Mode 1: Horizontal scanlines
    float3 crtScanlines(float3 texel, float2 screenCoords, float2 virtualRes, float intensity)
    {
        float brightBoost = 0.30;
        float scanIntensity = 0.30;

        float3 pixelHigh = ((1.0 + brightBoost) - (0.2 * texel)) * texel;
        float3 pixelLow = ((1.0 - scanIntensity) + (0.1 * texel)) * texel;

        float2 coords = frac(screenCoords * virtualRes) * 2.0 - float2(1.0, 1.0);
        float mask = 1.0 - abs(coords.y);

        float3 rasterColor = lerp(pixelLow, pixelHigh, mask);
        return lerp(texel, rasterColor, intensity);
    }

    // Mode 2: Pixel grid (dot matrix)
    float3 crtPixelGrid(float3 texel, float2 screenCoords, float2 virtualRes, float intensity)
    {
        float brightBoost = 0.30;
        float scanIntensity = 0.30;

        float3 pixelHigh = ((1.0 + brightBoost) - (0.2 * texel)) * texel;
        float3 pixelLow = ((1.0 - scanIntensity) + (0.1 * texel)) * texel;

        float2 coords = frac(screenCoords * virtualRes) * 2.0 - float2(1.0, 1.0);
        coords = coords * coords;
        float mask = 1.0 - coords.x - coords.y;

        float3 rasterColor = lerp(pixelLow, pixelHigh, mask);
        return lerp(texel, rasterColor, intensity);
    }

    // Mode 3: Subpixel simulation
    float3 crtSubpixel(float3 texel, float2 screenCoords, float2 virtualRes, float intensity)
    {
        float brightBoost = 0.30;
        float scanIntensity = 0.30;
        float subpixels = 3.0;

        float3 pixelHigh = ((1.0 + brightBoost) - (0.2 * texel)) * texel;
        float3 pixelLow = ((1.0 - scanIntensity) + (0.1 * texel)) * texel;

        // Scanline mask (Y axis)
        float2 coords = frac(screenCoords * virtualRes) * 2.0 - float2(1.0, 1.0);
        float yMask = 1.0 - abs(coords.y);

        // Subpixel mask (X axis) - 120 degree phase offsets per channel
        float3 offsets = 3.14159265 * float3(0.5, 0.5 - 0.6667, 0.5 - 1.3333);
        float2 omega = 3.14159265 * 2.0 * virtualRes;
        float2 angle = screenCoords * omega;
        float3 xfactors = (subpixels + sin(angle.x + offsets)) / (subpixels + 1.0);

        float3 rasterColor = lerp(pixelLow, pixelHigh, yMask) * xfactors;
        return lerp(texel, rasterColor, intensity);
    }

    // --- Glow line (scrolling scanline band) ---
    // Derived from cool-retro-term terminal_dynamic.frag:119-121
    float crtGlowLine(float2 coords, float2 virtualRes, float speed)
    {
        float threshold = (virtualRes.y + 120.0) * frac(_Time.y * speed);
        float coordY = (1.0 - coords.y) * virtualRes.y;
        return frac(smoothstep(-120.0, 0.0, coordY - threshold));
    }

    // --- Phosphor persistence (CRT phosphor decay simulation) ---
    float crtPhosphorFade(float2 coords, float speed, float decayRate, float minBrightness)
    {
        float beamPhase = frac(_Time.y * speed);
        float scanlinePos = 1.0 - coords.y;
        float timeSinceRefresh = frac(beamPhase - scanlinePos);
        float brightness = exp(-decayRate * timeSinceRefresh);
        brightness = lerp(minBrightness, 1.0, brightness);
        return brightness;
    }

    // --- Screen overlay (texture with alpha composited onto CRT content) ---
    float4 crtSampleOverlay(Texture2D tex, SamplerState samp, float2 screenUV,
        float2 position, float2 scale, float rotation, float rotationSpeed,
        float2 panning, float tileColumns, float tileRows, float tileIndex,
        float tiled, float opacity, float4 color)
    {
        float2 uv = screenUV;

        // Rotate around overlay center
        float theta = radians(rotation + _Time.z * rotationSpeed);
        float cs = cos(theta);
        float sn = sin(theta);
        uv = float2(
            (uv.x - position.x) * cs - (uv.y - position.y) * sn + position.x,
            (uv.x - position.x) * sn + (uv.y - position.y) * cs + position.y
        );

        // Remap to overlay bounds [0,1]
        uv = remap(uv,
            position - scale * 0.5,
            position + scale * 0.5,
            float2(0, 0), float2(1, 1)
        );

        // Clip outside [0,1] when not tiling
        float clip = 1.0;
        if (tiled < 0.5)
        {
            if (uv.x > 1 || uv.y > 1 || uv.x < 0 || uv.y < 0)
            {
                clip = 0.0;
            }
        }

        // Apply panning
        uv += panning * _Time.x;

        // Sprite sheet tile selection
        if (tileColumns > 1 || tileRows > 1)
        {
            float idx = floor(tileIndex);
            float col = fmod(idx, tileColumns);
            float row = floor(idx / tileColumns);
            row = (tileRows - 1.0) - row;
            uv = (uv + float2(col, row)) / float2(tileColumns, tileRows);
        }

        // Sample and apply color tint + opacity
        float4 overlayColor = tex.Sample(samp, uv) * color;
        overlayColor.a *= clip * opacity;

        return overlayColor;
    }

    // --- Edge detection (Sobel filter on screen content) ---
    float3 crtEdgeDetect(float3 original, Texture2D tex, SamplerState samp, float2 uv,
        float2 texelSize, float threshold, float softness,
        float3 edgeColor, float3 bgColor, float blend, float gain)
    {
        // Sample 3x3 neighborhood luminances
        float2 d = texelSize;
        float tl = dot(tex.Sample(samp, uv + float2(-d.x,  d.y)).rgb, float3(0.299, 0.587, 0.114));
        float tc = dot(tex.Sample(samp, uv + float2( 0.0,  d.y)).rgb, float3(0.299, 0.587, 0.114));
        float tr = dot(tex.Sample(samp, uv + float2( d.x,  d.y)).rgb, float3(0.299, 0.587, 0.114));
        float ml = dot(tex.Sample(samp, uv + float2(-d.x,  0.0)).rgb, float3(0.299, 0.587, 0.114));
        float mr = dot(tex.Sample(samp, uv + float2( d.x,  0.0)).rgb, float3(0.299, 0.587, 0.114));
        float bl = dot(tex.Sample(samp, uv + float2(-d.x, -d.y)).rgb, float3(0.299, 0.587, 0.114));
        float bc = dot(tex.Sample(samp, uv + float2( 0.0, -d.y)).rgb, float3(0.299, 0.587, 0.114));
        float br = dot(tex.Sample(samp, uv + float2( d.x, -d.y)).rgb, float3(0.299, 0.587, 0.114));

        // Sobel gradient (gain amplifies subtle edges in dark scenes)
        float gx = -tl - 2.0 * ml - bl + tr + 2.0 * mr + br;
        float gy = -tl - 2.0 * tc - tr + bl + 2.0 * bc + br;
        float edge = sqrt(gx * gx + gy * gy) * gain;

        // Threshold with softness falloff
        float edgeMask = smoothstep(threshold, threshold + max(softness, 0.001), edge);

        // Edge color on background
        float3 wireframe = lerp(bgColor, edgeColor, edgeMask);

        // Blend with original screen content
        return lerp(original, wireframe, blend);
    }

    // ddx/ddy fallback for edge detection on composited content (no texture re-sample)
    float3 crtEdgeDetectDDXY(float3 original, float threshold, float softness,
        float3 edgeColor, float3 bgColor, float blend, float gain)
    {
        float lum = dot(original, float3(0.299, 0.587, 0.114));
        float edge = length(float2(ddx(lum), ddy(lum))) * gain;
        float edgeMask = smoothstep(threshold * 0.1, (threshold + max(softness, 0.001)) * 0.1, edge);
        float3 wireframe = lerp(bgColor, edgeColor, edgeMask);
        return lerp(original, wireframe, blend);
    }

    // --- Sample screen texture with RGB shift ---
    // Derived from cool-retro-term terminal_static.frag:61-68
    float3 crtSampleWithRGBShift(Texture2D tex, SamplerState samp, float2 uv, float shift)
    {
        float2 displacement = float2(shift * 4.0 / _CRTVirtualResolution.x, 0.0);

        float3 centerColor = tex.Sample(samp, uv).rgb;
        float3 rightColor = tex.Sample(samp, uv + displacement).rgb;
        float3 leftColor = tex.Sample(samp, uv - displacement).rgb;

        float3 result;
        result.r = leftColor.r * 0.10 + rightColor.r * 0.30 + centerColor.r * 0.60;
        result.g = leftColor.g * 0.20 + rightColor.g * 0.20 + centerColor.g * 0.60;
        result.b = leftColor.b * 0.30 + rightColor.b * 0.10 + centerColor.b * 0.60;
        return result;
    }

    // --- Chroma / color conversion ---
    // Derived from cool-retro-term terminal_dynamic.frag:123-132
    float3 crtApplyChroma(float3 texColor, float3 fontColor, float3 bgColor, float chromaAmount)
    {
        float grey = dot(texColor, float3(0.299, 0.587, 0.114));
        float3 monoColor = lerp(bgColor, fontColor, grey);
        return lerp(monoColor, texColor, chromaAmount);
    }

    // --- Bloom approximation via mip sampling ---
    float3 crtBloomApprox(Texture2D tex, SamplerState samp, float2 uv, float bloomIntensity, float bloomRadius)
    {
        // Sample at a higher mip level for a blurred version
        float3 blurred = tex.SampleLevel(samp, uv, bloomRadius).rgb;

        // Energy-conserving bloom: add glow, normalize
        float bloomScale = 1.0 + max(bloomIntensity, 0.0);
        float3 bloom = clamp(blurred * bloomIntensity * bloomScale, 0.0, 0.5);
        return bloom;
    }

    // --- Texture2DArray variants for flipbook support ---
    #if defined(PROP_CRTFLIPBOOKTEXARRAY) || !defined(OPTIMIZER_ENABLED)
        float3 crtSampleWithRGBShiftArray(Texture2DArray tex, SamplerState samp, float2 uv, float shift, float frame, float2 uvDDX, float2 uvDDY)
        {
            float2 displacement = float2(shift * 4.0 / _CRTVirtualResolution.x, 0.0);

            float3 centerColor = _CRTFlipbookMonoSource
                ? tex.SampleGrad(samp, float3(uv, frame), uvDDX, uvDDY).rrr
                : tex.SampleGrad(samp, float3(uv, frame), uvDDX, uvDDY).rgb;
            float3 rightColor = _CRTFlipbookMonoSource
                ? tex.SampleGrad(samp, float3(uv + displacement, frame), uvDDX, uvDDY).rrr
                : tex.SampleGrad(samp, float3(uv + displacement, frame), uvDDX, uvDDY).rgb;
            float3 leftColor = _CRTFlipbookMonoSource
                ? tex.SampleGrad(samp, float3(uv - displacement, frame), uvDDX, uvDDY).rrr
                : tex.SampleGrad(samp, float3(uv - displacement, frame), uvDDX, uvDDY).rgb;

            float3 result;
            result.r = leftColor.r * 0.10 + rightColor.r * 0.30 + centerColor.r * 0.60;
            result.g = leftColor.g * 0.20 + rightColor.g * 0.20 + centerColor.g * 0.60;
            result.b = leftColor.b * 0.30 + rightColor.b * 0.10 + centerColor.b * 0.60;
            return result;
        }

        float3 crtBloomApproxArray(Texture2DArray tex, SamplerState samp, float2 uv, float bloomIntensity, float bloomRadius, float frame)
        {
            float3 blurred = _CRTFlipbookMonoSource
                ? tex.SampleLevel(samp, float3(uv, frame), bloomRadius).rrr
                : tex.SampleLevel(samp, float3(uv, frame), bloomRadius).rgb;

            float bloomScale = 1.0 + max(bloomIntensity, 0.0);
            float3 bloom = clamp(blurred * bloomIntensity * bloomScale, 0.0, 0.5);
            return bloom;
        }

        float3 crtSampleFlipbook(Texture2DArray tex, SamplerState samp, float2 uv, float currentFrame, float totalFrames, float crossfade, float2 crossfadeRange, float2 uvDDX, float2 uvDDY)
        {
            float frame0 = floor(currentFrame);
            float3 color = _CRTFlipbookMonoSource
                ? tex.SampleGrad(samp, float3(uv, frame0), uvDDX, uvDDY).rrr
                : tex.SampleGrad(samp, float3(uv, frame0), uvDDX, uvDDY).rgb;

            if (crossfade > 0)
            {
                float frame1 = floor(fmod(frame0 + 1.0, totalFrames));
                float3 colorNext = _CRTFlipbookMonoSource
                    ? tex.SampleGrad(samp, float3(uv, frame1), uvDDX, uvDDY).rrr
                    : tex.SampleGrad(samp, float3(uv, frame1), uvDDX, uvDDY).rgb;
                float t = smoothstep(crossfadeRange.x, crossfadeRange.y, frac(currentFrame));
                color = lerp(color, colorNext, t);
            }

            return color;
        }

        float3 crtSampleFlipbookRGBShift(Texture2DArray tex, SamplerState samp, float2 uv, float shift, float currentFrame, float totalFrames, float crossfade, float2 crossfadeRange, float2 uvDDX, float2 uvDDY)
        {
            float frame0 = floor(currentFrame);
            float3 color = crtSampleWithRGBShiftArray(tex, samp, uv, shift, frame0, uvDDX, uvDDY);

            if (crossfade > 0)
            {
                float frame1 = floor(fmod(frame0 + 1.0, totalFrames));
                float3 colorNext = crtSampleWithRGBShiftArray(tex, samp, uv, shift, frame1, uvDDX, uvDDY);
                float t = smoothstep(crossfadeRange.x, crossfadeRange.y, frac(currentFrame));
                color = lerp(color, colorNext, t);
            }

            return color;
        }
    #endif

    // --- Screen bezel SDF ---
    // Derived from cool-retro-term terminal_frame.frag:29-36
    float crtRoundedRectSDF(float2 uv, float2 halfSize, float radius)
    {
        float2 p = abs(uv - float2(0.5, 0.5)) - halfSize + float2(radius, radius);
        return length(max(p, float2(0.0, 0.0))) - radius;
    }

    // --- Main CRT function ---
    void applyCRT(inout PoiFragData poiFragData, in PoiMesh poiMesh, in PoiCam poiCam, in PoiLight poiLight, in PoiMods poiMods)
    {
        // =====================================================================
        // 1. Sample CRT mask
        // =====================================================================
        #if defined(PROP_CRTMASK) || !defined(OPTIMIZER_ENABLED)
            float2 maskUV = poiUV(poiMesh.uv[_CRTMaskUV], _CRTMask_ST);
            float crtMask = POI2D_SAMPLER_PAN(_CRTMask, _MainTex, maskUV, _CRTMaskPan)[_CRTMaskChannel];
        #else
            float crtMask = 1.0;
        #endif

        if (_CRTMaskInvert > 0)
        {
            crtMask = 1.0 - crtMask;
        }

        // Apply global mask
        if (_CRTGlobalMask > 0)
        {
            crtMask = maskBlend(crtMask, poiMods.globalMask[_CRTGlobalMask - 1], _CRTGlobalMaskBlendType);
        }

        if (crtMask <= 0.001) return;

        // =====================================================================
        // 2. Get base screen UV
        // =====================================================================
        float4 sourceTexST = _CRTScreenTex_ST;
        #if defined(PROP_CRTFLIPBOOKTEXARRAY) || !defined(OPTIMIZER_ENABLED)
            if (_CRTSourceMode == 1)
            {
                sourceTexST = _CRTFlipbookTexArray_ST;
            }
        #endif
        // Video mode (2) uses _CRTScreenTex_ST as its tiling/offset
        float2 screenUV = poiUV(poiMesh.uv[_CRTScreenTexUV], sourceTexST);
        float2 undistortedUV = screenUV;

        // =====================================================================
        // 3. Compute per-frame noise values (flickering, h-sync)
        // These are computed once per frame in cool-retro-term's vertex shader;
        // here we compute per-pixel but the values are frame-coherent via _Time
        // =====================================================================
        float2 frameNoiseUV = float2(frac(_Time.y / 2.048), frac(_Time.y / 1048.576));
        float frameNoiseR = crtHash12(frameNoiseUV * 512.0);
        float frameNoiseG = crtHash12(frameNoiseUV * 512.0 + float2(17.31, 43.71));

        // Flickering brightness
        // Derived from cool-retro-term terminal_dynamic.vert:42-45
        float flickerBrightness = 1.0;
        if (_CRTFlickerEnabled > 0)
        {
            flickerBrightness = 1.0 + (frameNoiseG - 0.5) * _CRTFlickerIntensity;
        }

        // H-sync parameters
        // Derived from cool-retro-term terminal_dynamic.vert:47-49
        float hSyncScale = 0.0;
        float hSyncFreq = 0.0;
        if (_CRTHSyncEnabled > 0)
        {
            float hSyncStrength = lerp(0.05, 0.35, _CRTHSync);
            float randval = hSyncStrength - frameNoiseR;
            hSyncScale = step(0.0, randval) * randval * hSyncStrength * _CRTHSync;
            hSyncFreq = lerp(4.0, 40.0, frameNoiseG);
        }

        // =====================================================================
        // 4. Apply screen curvature (barrel distortion)
        // =====================================================================
        float isOnScreen = 1.0;
        if (_CRTCurvatureEnabled > 0)
        {
            screenUV = crtDistortCoordinates(screenUV, _CRTCurvature * 0.6);

            // Check if the distorted coordinate is still on-screen
            float2 screenStep = step(float2(0.0, 0.0), screenUV) * step(screenUV, float2(1.0, 1.0));
            isOnScreen = screenStep.x * screenStep.y;
        }

        // =====================================================================
        // 5. Apply h-sync distortion
        // Derived from cool-retro-term terminal_dynamic.frag:141-142
        // =====================================================================
        if (_CRTHSyncEnabled > 0)
        {
            float dst = sin((screenUV.y + _Time.y) * hSyncFreq);
            screenUV.x += dst * hSyncScale;
        }

        // =====================================================================
        // 6. Compute per-pixel noise for jitter and static
        // Derived from cool-retro-term terminal_dynamic.frag:144
        // =====================================================================
        float2 noiseScrollUV = screenUV * (_CRTVirtualResolution.x * 0.75 / 512.0)
            + float2(frac(_Time.y / 0.051), frac(_Time.y / 0.237));
        float noiseR = crtHash12(noiseScrollUV * 512.0);
        float noiseG = crtHash12(noiseScrollUV * 512.0 + float2(7.23, 91.41));
        float noiseB = crtHash12(noiseScrollUV * 512.0 + float2(53.17, 23.89));
        float noiseA = crtHash12(noiseScrollUV * 512.0 + float2(31.79, 67.53));

        // =====================================================================
        // 7. Apply jitter (UV displacement from noise)
        // Derived from cool-retro-term terminal_dynamic.frag:146
        // =====================================================================
        if (_CRTJitterEnabled > 0)
        {
            float2 jitterDisplacement = float2(0.007, 0.002) * _CRTJitter;
            screenUV += (float2(noiseB, noiseA) - float2(0.5, 0.5)) * jitterDisplacement * _CRTJitter;
        }

        // =====================================================================
        // 8. Sample screen content
        // =====================================================================
        float3 screenColor = float3(0.0, 0.0, 0.0);
        float2 sampleUV = screenUV;

        // --- Video source (global texture from VRChat video players) ---
        if (_CRTSourceMode > 1)
        {
            sampleUV = screenUV;

            // Flip Y if needed (some video sources are inverted)
            if (_CRTVideoFlipY > 0)
            {
                sampleUV.y = 1.0 - sampleUV.y;
            }

            // Apply positioning: scale, offset, side offset
            {
                float4 vidScaleOffset = _CRTVideoScaleOffset;
                vidScaleOffset.xy = 1.0 - vidScaleOffset.xy;

                float4 sideOff = float4(
                    -_CRTVideoSideOffset.x,
                    _CRTVideoSideOffset.y,
                    -_CRTVideoSideOffset.z,
                    _CRTVideoSideOffset.w
                );

                float2 bottomLeft = float2(0, 0) + vidScaleOffset.xy * 0.5 + vidScaleOffset.zw + sideOff.xz;
                float2 topRight = float2(1, 1) - vidScaleOffset.xy * 0.5 + vidScaleOffset.zw + sideOff.yw;

                sampleUV = remap(sampleUV, bottomLeft, topRight, float2(0, 0), float2(1, 1));
            }

            // Aspect ratio correction: letterbox/pillarbox to fit video into screen
            // Uses user-specified screen aspect (e.g. 4:3) vs actual video dimensions
            float videoInBounds = 1.0;
            if (_CRTVideoAspectCorrect > 0)
            {
                float videoW = _Udon_VideoTex_TexelSize.z;
                float videoH = _Udon_VideoTex_TexelSize.w;
                if (videoW > 16 && videoH > 16)
                {
                    float videoAspect = videoW / videoH;
                    float screenAspect = _CRTVideoScreenAspect.x / max(_CRTVideoScreenAspect.y, 0.001);
                    if (videoAspect > screenAspect)
                    {
                        // Video wider than screen -> letterbox (black bars top/bottom)
                        float scale = screenAspect / videoAspect;
                        sampleUV.y = (sampleUV.y - 0.5) / scale + 0.5;
                    }
                    else
                    {
                        // Video taller than screen -> pillarbox (black bars left/right)
                        float scale = videoAspect / screenAspect;
                        sampleUV.x = (sampleUV.x - 0.5) / scale + 0.5;
                    }
                    // Black out regions outside [0,1] (the letterbox/pillarbox bars)
                    float2 uvClip = step(float2(0.0, 0.0), sampleUV) * step(sampleUV, float2(1.0, 1.0));
                    videoInBounds = uvClip.x * uvClip.y;
                }
            }

            // Check if video is actually available (dimensions > 16px)
            float videoAvailable = step(17.0, _Udon_VideoTex_TexelSize.z);

            // _Udon_VideoTex is declared as sampler2D by Poiyomi, so use tex2D/tex2Dlod
            if (_CRTRGBShiftEnabled > 0)
            {
                float2 displacement = float2(_CRTRGBShift * 4.0 / _CRTVirtualResolution.x, 0.0);
                float3 centerColor = tex2D(_Udon_VideoTex, sampleUV).rgb;
                float3 rightColor = tex2D(_Udon_VideoTex, sampleUV + displacement).rgb;
                float3 leftColor = tex2D(_Udon_VideoTex, sampleUV - displacement).rgb;
                screenColor.r = leftColor.r * 0.10 + rightColor.r * 0.30 + centerColor.r * 0.60;
                screenColor.g = leftColor.g * 0.20 + rightColor.g * 0.20 + centerColor.g * 0.60;
                screenColor.b = leftColor.b * 0.30 + rightColor.b * 0.10 + centerColor.b * 0.60;
            }
            else
            {
                screenColor = tex2D(_Udon_VideoTex, sampleUV).rgb;
            }
            screenColor *= videoAvailable * videoInBounds;

            // Bloom for video
            if (_CRTBloomEnabled > 0)
            {
                float3 blurred = tex2Dlod(_Udon_VideoTex, float4(sampleUV, 0, _CRTBloomRadius)).rgb;
                float bloomIntensity = _CRTBloom * 2.5;
                float bloomScale = 1.0 + max(bloomIntensity, 0.0);
                float3 bloomAdd = clamp(blurred * bloomIntensity * bloomScale, 0.0, 0.5);
                screenColor *= bloomScale;
                screenColor += bloomAdd * videoAvailable * videoInBounds;
                screenColor /= bloomScale;
            }
        }
        // --- Flipbook source ---
        else
        #if defined(PROP_CRTFLIPBOOKTEXARRAY) || !defined(OPTIMIZER_ENABLED)
        if (_CRTSourceMode > 0)
        {
            // Apply positioning: scale, offset, side offset
            // Same approach as Poiyomi Flipbook: scale is inverted, bounding box remap
            float4 fbScaleOffset = _CRTFlipbookScaleOffset;
            fbScaleOffset.xy = 1.0 - fbScaleOffset.xy;

            float4 sideOff = float4(
                -_CRTFlipbookSideOffset.x,  // Left (negated)
                _CRTFlipbookSideOffset.y,    // Right
                -_CRTFlipbookSideOffset.z,   // Down (negated)
                _CRTFlipbookSideOffset.w     // Up
            );

            float2 bottomLeft = float2(0, 0) + fbScaleOffset.xy * 0.5 + fbScaleOffset.zw + sideOff.xz;
            float2 topRight = float2(1, 1) - fbScaleOffset.xy * 0.5 + fbScaleOffset.zw + sideOff.yw;

            sampleUV = remap(screenUV, bottomLeft, topRight, float2(0, 0), float2(1, 1));
            sampleUV += _CRTFlipbookTexArrayPan * _Time.x;

            // Compute gradient derivatives for correct mip selection
            float2 uvDDX = ddx(sampleUV);
            float2 uvDDY = ddy(sampleUV);

            // Compute current frame index
            float totalFrames = max(_CRTFlipbookTotalFrames, 1.0);
            float currentFrame;
            if (_CRTFlipbookManualFrame > 0)
            {
                currentFrame = _CRTFlipbookCurrentFrame;
            }
            else
            {
                currentFrame = (_Time.y * _CRTFlipbookFPS + _CRTFlipbookFrameOffset);
            }
            currentFrame = fmod(currentFrame, totalFrames);
            if (currentFrame < 0) currentFrame += totalFrames;

            if (_CRTRGBShiftEnabled > 0)
            {
                screenColor = crtSampleFlipbookRGBShift(_CRTFlipbookTexArray, sampler_CRTFlipbookTexArray,
                    sampleUV, _CRTRGBShift, currentFrame, totalFrames,
                    _CRTFlipbookCrossfade, _CRTFlipbookCrossfadeRange, uvDDX, uvDDY);
            }
            else
            {
                screenColor = crtSampleFlipbook(_CRTFlipbookTexArray, sampler_CRTFlipbookTexArray,
                    sampleUV, currentFrame, totalFrames,
                    _CRTFlipbookCrossfade, _CRTFlipbookCrossfadeRange, uvDDX, uvDDY);
            }

            // Bloom for flipbook
            if (_CRTBloomEnabled > 0)
            {
                float3 bloomAdd = crtBloomApproxArray(_CRTFlipbookTexArray, sampler_CRTFlipbookTexArray,
                    sampleUV, _CRTBloom * 2.5, _CRTBloomRadius, floor(currentFrame));
                float bloomScale = 1.0 + max(_CRTBloom * 2.5, 0.0);
                screenColor *= bloomScale;
                screenColor += bloomAdd;
                screenColor /= bloomScale;
            }
        }
        else
        #endif
        // --- Static texture source ---
        {
            #if defined(PROP_CRTSCREENTEX) || !defined(OPTIMIZER_ENABLED)
                sampleUV = screenUV + _CRTScreenTexPan * _Time.x;

                if (_CRTRGBShiftEnabled > 0)
                {
                    screenColor = crtSampleWithRGBShift(_CRTScreenTex, sampler_CRTScreenTex, sampleUV, _CRTRGBShift);
                }
                else
                {
                    screenColor = _CRTScreenTex.Sample(sampler_CRTScreenTex, sampleUV).rgb;
                }
            #endif

            // Bloom for static texture
            if (_CRTBloomEnabled > 0)
            {
                #if defined(PROP_CRTSCREENTEX) || !defined(OPTIMIZER_ENABLED)
                    float3 bloomAdd = crtBloomApprox(_CRTScreenTex, sampler_CRTScreenTex, sampleUV, _CRTBloom * 2.5, _CRTBloomRadius);
                    float bloomScale = 1.0 + max(_CRTBloom * 2.5, 0.0);
                    screenColor *= bloomScale;
                    screenColor += bloomAdd;
                    screenColor /= bloomScale;
                #endif
            }
        }

        // =====================================================================
        // 8b. Screen gamma correction (brightens dark scenes before edge detection)
        // =====================================================================
        screenColor = pow(max(screenColor, 0.0), _CRTScreenGamma);

        // =====================================================================
        // 9a. Edge detection (before overlay — wireframe map + clean overlay)
        // =====================================================================
        if (_CRTEdgeDetectEnabled > 0 && _CRTEdgeBeforeOverlay > 0.5)
        {
            #if defined(PROP_CRTSCREENTEX) || !defined(OPTIMIZER_ENABLED)
                float2 edgeTexel = 1.0 / _CRTVirtualResolution;
                screenColor = crtEdgeDetect(screenColor, _CRTScreenTex, sampler_CRTScreenTex,
                    sampleUV, edgeTexel, _CRTEdgeThreshold, _CRTEdgeSoftness,
                    _CRTEdgeColor.rgb, _CRTEdgeBGColor.rgb, _CRTEdgeBlend, _CRTEdgeGain);
            #endif
        }

        // =====================================================================
        // 9b. Overlay compositing
        // =====================================================================
        #if defined(PROP_CRTOVERLAYTEX) || !defined(OPTIMIZER_ENABLED)
            if (_CRTOverlayEnabled > 0)
            {
                float4 overlay = crtSampleOverlay(_CRTOverlayTex, sampler_CRTOverlayTex, screenUV,
                    _CRTOverlayPosition, _CRTOverlayScale, _CRTOverlayRotation, _CRTOverlayRotationSpeed,
                    _CRTOverlayTexPan, _CRTOverlayTileColumns, _CRTOverlayTileRows, _CRTOverlayTileIndex,
                    _CRTOverlayTiled, _CRTOverlayOpacity, _CRTOverlayColor);
                screenColor = lerp(screenColor, overlay.rgb, overlay.a);
            }
        #endif

        // =====================================================================
        // 9c. Edge detection (after overlay — everything gets wireframe treatment)
        // =====================================================================
        if (_CRTEdgeDetectEnabled > 0 && _CRTEdgeBeforeOverlay < 0.5)
        {
            screenColor = crtEdgeDetectDDXY(screenColor, _CRTEdgeThreshold, _CRTEdgeSoftness,
                _CRTEdgeColor.rgb, _CRTEdgeBGColor.rgb, _CRTEdgeBlend, _CRTEdgeGain);
        }

        // =====================================================================
        // 10. Apply chroma / color conversion
        // =====================================================================
        float3 fontColor = poiThemeColor(poiMods, _CRTFontColor.rgb, _CRTFontColorThemeIndex);
        screenColor = crtApplyChroma(screenColor, fontColor, _CRTBackgroundColor.rgb, _CRTChromaColor);

        // =====================================================================
        // 11. Apply rasterization (scanlines / pixel grid / subpixel)
        // =====================================================================
        if (_CRTRasterMode > 0)
        {
            float rasterIntensity = _CRTRasterIntensity;

            if (_CRTRasterMode < 2)
            {
                screenColor = crtScanlines(screenColor, screenUV, _CRTVirtualResolution, rasterIntensity);
            }
            else if (_CRTRasterMode < 3)
            {
                screenColor = crtPixelGrid(screenColor, screenUV, _CRTVirtualResolution, rasterIntensity);
            }
            else
            {
                screenColor = crtSubpixel(screenColor, screenUV, _CRTVirtualResolution, rasterIntensity);
            }
        }

        // =====================================================================
        // 12. Add static noise
        // Derived from cool-retro-term terminal_dynamic.frag:149
        // =====================================================================
        if (_CRTNoiseEnabled > 0)
        {
            float dist = length(float2(0.5, 0.5) - screenUV);
            float noiseVal = noiseA * _CRTNoiseIntensity * (1.0 - dist * 1.3);
            screenColor += float3(noiseVal, noiseVal, noiseVal);
        }

        // =====================================================================
        // 12b. Apply phosphor persistence
        // =====================================================================
        if (_CRTPhosphorEnabled > 0)
        {
            float phosphorSpeed = _CRTPhosphorSpeed;
            if (_CRTGlowLineEnabled > 0 && _CRTPhosphorUseGlowSpeed > 0)
            {
                phosphorSpeed = _CRTGlowLineSpeed;
            }
            float phosphorFade = crtPhosphorFade(screenUV, phosphorSpeed, _CRTPhosphorDecay, _CRTPhosphorMinBrightness);
            screenColor *= phosphorFade;
        }

        // =====================================================================
        // 13. Add glow line
        // =====================================================================
        if (_CRTGlowLineEnabled > 0)
        {
            float glowLine = crtGlowLine(screenUV, _CRTVirtualResolution, _CRTGlowLineSpeed);
            screenColor += fontColor * glowLine * _CRTGlowLineIntensity * 0.2;
        }

        // =====================================================================
        // 14. Apply flickering brightness
        // =====================================================================
        if (_CRTFlickerEnabled > 0)
        {
            screenColor *= flickerBrightness;
        }

        // =====================================================================
        // 15. Apply brightness
        // =====================================================================
        screenColor *= _CRTBrightness;

        // =====================================================================
        // 16. Hue shift
        // =====================================================================
        if (_CRTHueShiftEnabled > 0)
        {
            screenColor = hueShift(screenColor, frac(_CRTHueShift + _CRTHueShiftSpeed * _Time.x), _CRTHueShiftColorSpace, 1);
        }

        // =====================================================================
        // 17. Audio Link
        // =====================================================================
        #ifdef POI_AUDIOLINK
            if (poiMods.audioLinkAvailable && _CRTALEnabled > 0)
            {
                // Intensity modulation
                float alIntensity = poiMods.audioLink[_CRTALBand];
                screenColor *= lerp(_CRTALMultipliers.x, _CRTALMultipliers.y, alIntensity);

                // ColorChord
                if (_CRTALColorChord > 0)
                {
                    float3 ccColor = AudioLinkLerp(ALPASS_CCSTRIP + float2(_CRTALBand * 0.25 * AUDIOLINK_WIDTH, 0)).rgb;
                    screenColor *= ccColor;
                }

                // Audio-driven hue shift
                if (_CRTALHueShift > 0)
                {
                    float alHueShift = poiMods.audioLink[_CRTALHueBand] * _CRTALHueShiftAmount;
                    screenColor = hueShift(screenColor, alHueShift, 0, 0);
                }
            }
        #endif

        // =====================================================================
        // 18. Bezel rendering
        // Derived from cool-retro-term terminal_frame.frag
        // =====================================================================
        float bezelMask = 0.0;
        float3 bezelOutput = float3(0.0, 0.0, 0.0);

        if (_CRTBezelEnabled > 0)
        {
            float2 halfSize = float2(0.5 - _CRTBezelSize, 0.5 - _CRTBezelSize);
            float sdfDist = crtRoundedRectSDF(undistortedUV, halfSize, _CRTScreenRadius);

            // Inside screen: negative SDF. Outside: positive.
            float edgeSoft = 0.005;
            float inScreen = smoothstep(edgeSoft, -edgeSoft, sdfDist);
            float inBezel = smoothstep(edgeSoft + _CRTBezelSize, -edgeSoft, sdfDist) * (1.0 - inScreen);

            // Directional shadow on bezel
            // Derived from cool-retro-term terminal_frame.frag:47-62
            float sw = 0.3;
            float2 bc = undistortedUV;
            float e = min(smoothstep(-sw, sw, bc.x - bc.y),
                          smoothstep(-sw, sw, bc.x - (1.0 - bc.y)));
            float s = min(smoothstep(-sw, sw, bc.y - bc.x),
                          smoothstep(-sw, sw, bc.x - (1.0 - bc.y)));
            float w = min(smoothstep(-sw, sw, bc.y - bc.x),
                          smoothstep(-sw, sw, (1.0 - bc.x) - bc.y));
            float n = min(smoothstep(-sw, sw, bc.x - bc.y),
                          smoothstep(-sw, sw, (1.0 - bc.x) - bc.y));
            float frameShadow = (e * 0.66 + w * 0.66 + n * 0.33 + s);
            frameShadow = frameShadow * 0.5 + 0.5;

            // Glass reflection inside screen
            // Derived from cool-retro-term terminal_frame.frag:72
            float glassBase = undistortedUV.x * (1.0 - undistortedUV.y) * undistortedUV.y * (1.0 - undistortedUV.x) * 25.0;
            float glass = clamp(_CRTAmbientLight * pow(abs(glassBase), 0.5) * inScreen, 0.0, 1.0);

            // Bezel color with shadow
            float3 bezelTint = _CRTBezelColor.rgb * frameShadow;
            // Add subtle noise to prevent banding
            float bezelNoise = crtHash12(undistortedUV * 1000.0) * 0.04;
            bezelTint = clamp(bezelTint + float3(bezelNoise, bezelNoise, bezelNoise), 0.0, 1.0);

            bezelOutput = bezelTint * inBezel + float3(glass, glass, glass);
            bezelMask = saturate(inBezel + glass);

            // If curvature clipping is on, also mask screen to the SDF boundary
            if (_CRTCurvatureEnabled > 0 && _CRTCurvatureClip > 0)
            {
                isOnScreen *= inScreen;
            }
        }

        // =====================================================================
        // 19. Final compositing
        // =====================================================================
        // Clip screen content to valid area
        screenColor *= isOnScreen;

        // Combine screen + bezel
        float3 crtOutput = screenColor * (1.0 - bezelMask) + bezelOutput;

        // Apply emission intensity and mask
        crtOutput *= _CRTEmissionIntensity * crtMask;

        // Output as emission
        poiFragData.emission += crtOutput;
    }
#endif
